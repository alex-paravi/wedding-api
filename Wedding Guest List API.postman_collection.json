  "item": [
    {
      "name": "Get All Guests",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "",
              "const template = `",
              "<style>",
              "  body { font-family: Arial, sans-serif; padding: 16px; }",
              "  h2 { color: #333; }",
              "  table { border-collapse: collapse; width: 100%; }",
              "  th { background-color: #FF6C37; color: white; padding: 10px 14px; text-align: left; }",
              "  td { padding: 8px 14px; border-bottom: 1px solid #ddd; }",
              "  tr:hover { background-color: #f5f5f5; }",
              "  .confirmed { color: green; font-weight: bold; }",
              "  .not-confirmed { color: #999; }",
              "</style>",
              "<h2>Wedding Guest List ({{count}} guests)</h2>",
              "<table>",
              "  <thead>",
              "    <tr>",
              "      <th>#</th>",
              "      <th>Name</th>",
              "      <th>Confirmed</th>",
              "      <th>Created At</th>",
              "      <th>Updated At</th>",
              "    </tr>",
              "  </thead>",
              "  <tbody>",
              "    {{#each guests}}",
              "    <tr>",
              "      <td>{{id}}</td>",
              "      <td>{{name}}</td>",
              "      <td class=\"{{#if is_confirmed}}confirmed{{else}}not-confirmed{{/if}}\">",
              "        {{#if is_confirmed}}✔ Yes{{else}}✘ No{{/if}}",
              "      </td>",
              "      <td>{{created_at}}</td>",
              "      <td>{{updated_at}}</td>",
              "    </tr>",
              "    {{/each}}",
              "  </tbody>",
              "</table>",
              "`;",
              "",
              "pm.visualizer.set(template, {",
              "  guests: response,",
              "  count: response.length",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
